# NEXUS Configuration Template
# Copy this to .env and fill in your details.

# 1. LLM Provider (gemini, openai, anthropic, or local)
NEXUS_LLM_PROVIDER=gemini

# 2. API Keys
GEMINI_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here

# 3. Local LLM Endpoints (for Ollama, vLLM, or LM Studio)
# Default is Ollama
NEXUS_LOCAL_ENDPOINT=http://localhost:11434
NEXUS_LOCAL_MODEL_ARCHITECT=deepseek-coder-v2:16b
NEXUS_LOCAL_MODEL_SWARM=llama3.1:8b

# 4. Hardware Awareness
# Set to 'auto' to use nvidia-smi/pynvml, or force a profile (e.g., 'Jetson_Orin')
NEXUS_HARDWARE_PROFILE=auto
